# Copy this file to .env and fill with real values.
# Keep .env permissions restricted: chmod 600 .env

# Resend API key — get from https://resend.com/api-keys
RESEND_API_KEY=re_your_api_key_here

# Email addresses
# ALERT_FROM must be a verified sender in your Resend account
ALERT_FROM=alerts@yourdomain.com
ALERT_TO=your-email@gmail.com

# Optional: set to 1 to send recovery email when speed returns above threshold
SEND_RECOVERY_EMAIL=1
