# Copy this file to .env and fill with real values.
# Keep .env permissions restricted: chmod 600 .env

# Gmail SMTP credentials
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-gmail-app-password

# Email addresses
ALERT_FROM=your-email@gmail.com
ALERT_TO=recipient@example.com

# Optional: set to 1 to send recovery email when speed returns above threshold
SEND_RECOVERY_EMAIL=1
